# Core
APP_ENV=local
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# API
RAG_API_HOST=0.0.0.0
RAG_API_PORT=8080
COMPANY_KNOWLEDGE_UI_PORT=5173

# Databases
APP_DATABASE_URL=sqlite:///./.cache/rag_api.sqlite3
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cloudrag
POSTGRES_USER=cloudrag
POSTGRES_PASSWORD=cloudrag

REDIS_HOST=redis
REDIS_PORT=6379

QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Microsoft Graph / OneNote auth placeholders
GRAPH_API_BASE_URL=https://graph.microsoft.com/v1.0
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
ONENOTE_GRAPH_MODE=mock
ONENOTE_AUTH_MODE=device_code
GRAPH_ONENOTE_TENANT_ID=
GRAPH_ONENOTE_CLIENT_ID=
GRAPH_ONENOTE_SCOPES=Notes.Read
GRAPH_ONENOTE_SCOPE_MODE=me
GRAPH_ONENOTE_SITE_HOSTNAME=
GRAPH_ONENOTE_SITE_SCOPE=
GRAPH_ONENOTE_NOTEBOOK_SCOPE=

# Sync
ONENOTE_SYNC_INTERVAL_SECONDS=900
WORKER_POLL_INTERVAL_SECONDS=30
ONENOTE_PAGE_PAGE_SIZE=100
ONENOTE_CHUNK_SIZE_CHARS=2000
ONENOTE_CHUNK_OVERLAP_CHARS=300
ONENOTE_PROCEDURE_CHUNK_MAX_CHARS=5000
RAG_CONTEXT_MAX_CHARS=10000
ONENOTE_VECTOR_COLLECTION=onenote_chunks
ONENOTE_TOKEN_CACHE_PATH=.cache/onenote_token_cache.json
ONENOTE_RETRY_ATTEMPTS=3
ONENOTE_RETRY_BACKOFF_SECONDS=1.0
ONENOTE_INCREMENTAL_LOOKBACK_SECONDS=0
ATTACHMENT_STORAGE_DIR=.cache/attachments
EMBEDDING_VECTOR_SIZE=32

# Operations
OPS_JOB_MAX_ATTEMPTS=5
OPS_JOB_BASE_BACKOFF_SECONDS=30
OPS_JOB_MAX_BACKOFF_SECONDS=1800
OPS_WORKER_BATCH_SIZE=10
ONENOTE_RECONCILIATION_INTERVAL_SECONDS=86400

# Observability
OTEL_ENABLED=false
OTEL_SERVICE_NAME=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_CONSOLE_EXPORTER=false

# LLM and local mock provider
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_EMBEDDING_PROVIDER=token-hash-v1
DEFAULT_MODEL_NAME=gpt-oss:120b-cloud
LLM_OPENAI_BASE_URL=http://host.docker.internal:11434/v1
LLM_OPENAI_API_KEY=ollama
LLM_REQUEST_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1400
MOCK_API_KEY=cloudrag-local-key
MOCK_TOP_K=3
RAG_API_KEY=cloudrag-rag-key
RETRIEVAL_PROVIDER=qdrant
RETRIEVAL_VECTOR_COLLECTIONS=onenote_chunks
RETRIEVAL_CANDIDATE_MULTIPLIER=3
RETRIEVAL_MIN_KEYWORD_OVERLAP=1
# 0 = scan the whole accessible corpus so title matches are never missed.
RETRIEVAL_LEXICAL_SCAN_LIMIT=0
CLARIFY_ENABLED=true
CLARIFY_CLOSENESS_RATIO=0.6
CLARIFY_MAX_OPTIONS=5
RERANK_ENABLED=true

# Microsoft Entra ID / OIDC backend auth
AUTH_ENABLED=false
AUTH_REQUIRED=false
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
AUTH_SESSION_TTL_HOURS=168
AUTH_REGISTRATION_TENANT_ID=local-tenant
AUTH_REGISTRATION_ACL_TAGS=public,employees
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
AUTH_BOOTSTRAP_ADMIN_PASSWORD=change-this-admin-password
AUTH_BOOTSTRAP_ADMIN_NAME=System Administrator
AUTH_TENANT_ID=
AUTH_CLIENT_ID=
AUTH_ALLOWED_AUDIENCES=
AUTH_OIDC_METADATA_URL=
AUTH_REQUIRED_SCOPES=
AUTH_GROUP_CLAIM=groups
AUTH_ROLE_CLAIM=roles
AUTH_GROUP_SCOPE_MAP_JSON={}
AUTH_ROLE_SCOPE_MAP_JSON={}
AUTH_DEFAULT_ACL_TAGS=public,employees
AUTH_JWKS_CACHE_SECONDS=86400
AUTH_LEEWAY_SECONDS=60
SECURITY_AUDIT_ENABLED=true
SECURITY_AUDIT_LOG_TO_DB=true

# Open WebUI
OPENWEBUI_PORT=3000
WEBUI_SECRET_KEY=cloud-rag-local-secret
ENABLE_PERSISTENT_CONFIG=false
ENABLE_OLLAMA_API=false
WEBUI_URL=http://localhost:3000
ENABLE_OAUTH_SIGNUP=false
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CLIENT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:3000/oauth/microsoft/callback
OPENID_PROVIDER_URL=
OAUTH_SCOPES=openid email profile
OAUTH_GROUP_CLAIM=groups
ENABLE_OAUTH_GROUP_MANAGEMENT=false
ENABLE_OAUTH_GROUP_CREATION=false
