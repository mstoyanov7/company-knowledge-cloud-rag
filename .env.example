# Core
APP_ENV=local
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# API
RAG_API_HOST=0.0.0.0
RAG_API_PORT=8080

# Databases
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cloudrag
POSTGRES_USER=cloudrag
POSTGRES_PASSWORD=cloudrag

REDIS_HOST=redis
REDIS_PORT=6379

QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Graph auth placeholders
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SHAREPOINT_SCOPE=sites/onboarding
GRAPH_ONENOTE_SCOPE=notebooks/onboarding

# Sync
SHAREPOINT_SYNC_INTERVAL_SECONDS=300
ONENOTE_SYNC_INTERVAL_SECONDS=900
WORKER_POLL_INTERVAL_SECONDS=30

# LLM and local mock provider
DEFAULT_LLM_PROVIDER=mock
DEFAULT_EMBEDDING_PROVIDER=mock
DEFAULT_MODEL_NAME=mock-onboarding-assistant
MOCK_API_KEY=cloudrag-local-key
MOCK_TOP_K=3

# Open WebUI
OPENWEBUI_PORT=3000
WEBUI_SECRET_KEY=cloud-rag-local-secret
